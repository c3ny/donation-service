# ─── SERVER ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ─── MONGODB ──────────────────────────────────────────────────────────────────
# Docker: MONGO_HOST=mongo_donation_service | Local: MONGO_HOST=localhost
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DBNAME=donation_service
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=

# ─── AUTH ─────────────────────────────────────────────────────────────────────
# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Deve ser IGUAL ao JWT_SECRET de todos os outros serviços
JWT_SECRET=
